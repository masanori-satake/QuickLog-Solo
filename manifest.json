{
  "manifest_version": 3,
  "name": "QuickLog-Solo",
  "version": "0.4.1",
  "description": "1秒で記録、1秒で集計、1秒で安心 - ミニマリスト向けサイドパネル工数管理ツール",
  "permissions": [
    "sidePanel"
  ],
  "action": {
    "default_title": "QuickLog-Soloを開く",
    "default_icon": "assets/icon.svg"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "192": "assets/icon.svg",
    "512": "assets/icon.svg"
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  }
}
