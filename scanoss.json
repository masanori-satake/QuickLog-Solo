{
  "bom": {
    "include": [
      {
        "purl": "pkg:github/muhammetdag/paradisesteamlibrary"
      },
      {
        "purl": "pkg:github/rcconsult/ppxai"
      }
    ]
  },
  "settings": {
    "skip": {
      "patterns": {
        "scanning": [
          "node_modules",
          ".git",
          ".github",
          "tests",
          "scripts",
          "docs",
          "releases",
          "test-results",
          "shared/assets",
          "projects/app/shared",
          "projects/studio/shared",
          "projects/category-editor/shared",
          "projects/web/shared",
          "screenshots",
          ".scanossignore",
          "scanoss.json",
          "package-lock.json",
          ".gitignore",
          ".vercelignore",
          ".stylelintignore",
          ".stylelintrc.json",
          ".pre-commit-config.yaml",
          "eslint.config.js",
          "jest.config.cjs",
          "jest.setup.js",
          "playwright.config.js",
          "*.png",
          "*.zip",
          "*.svg",
          "*.jpg",
          "*.jpeg",
          "*.gif",
          "*.ico",
          "*.webp",
          "*.rev",
          "*.idx",
          "*.pack",
          "*.woff",
          "*.woff2",
          "*.ttf",
          "*.eot"
        ]
      }
    }
  }
}
