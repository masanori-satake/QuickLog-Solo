{
  "bom": {
    "include": [
      {
        "purl": "pkg:github/muhammetdag/paradisesteamlibrary"
      },
      {
        "purl": "pkg:github/rcconsult/ppxai"
      }
    ]
  },
  "settings": {
    "skip": {
      "patterns": {
        "scanning": [
          "node_modules",
          ".*",
          "tests",
          "scripts",
          "docs",
          "releases",
          "test-results",
          "shared/assets",
          "projects/app/shared",
          "projects/studio/shared",
          "projects/category-editor/shared",
          "projects/web/shared",
          "screenshots",
          "package-lock.json",
          "scanoss.json",
          "*.png",
          "*.zip",
          "*.svg",
          "*.jpg",
          "*.jpeg",
          "*.gif",
          "*.ico",
          "*.webp",
          "*.rev",
          "*.idx",
          "*.pack",
          "*.woff",
          "*.woff2",
          "*.ttf",
          "*.eot",
          "*.map",
          "*.min.js",
          "shared/js/locales"
        ]
      }
    }
  }
}
