{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QuickLog-Solo Category Export/Backup Schema",
  "description": "Schema for a single line in category export or backup NDJSON files used in QuickLog-Solo.",
  "definitions": {
    "color": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "tertiary",
        "error",
        "neutral",
        "outline",
        "teal",
        "green",
        "yellow",
        "orange",
        "pink",
        "indigo",
        "brown",
        "cyan"
      ]
    },
    "animationId": {
      "type": "string",
      "maxLength": 50
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 50
      }
    }
  },
  "oneOf": [
    {
      "title": "Regular Category",
      "type": "object",
      "required": [
        "kind",
        "type",
        "name",
        "color"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "QuickLogSolo/Category",
          "description": "Identifier for the category data kind."
        },
        "type": {
          "type": "string",
          "const": "category",
          "description": "Indicates this item is a regular category."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "Display name of the category."
        },
        "color": {
          "$ref": "#/definitions/color",
          "description": "The theme color identifier for the category."
        },
        "tags": {
          "$ref": "#/definitions/tags",
          "description": "List of tags associated with the category."
        },
        "animation": {
          "$ref": "#/definitions/animationId",
          "description": "The animation ID to play when this category is active."
        }
      }
    },
    {
      "title": "Page Break",
      "type": "object",
      "required": [
        "kind",
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "QuickLogSolo/Category",
          "description": "Identifier for the category data kind."
        },
        "type": {
          "type": "string",
          "const": "page-break",
          "description": "Indicates this item is a page break."
        },
        "name": {
          "type": "string",
          "description": "Internal name or unique identifier for the page break."
        }
      }
    }
  ]
}
