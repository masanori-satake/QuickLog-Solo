{
  "name": "app",
  "version": "0.32.13",
  "description": "「1秒で記録、1秒で集計、1秒で安心」をコンセプトにした、ミニマリスト向けサイドパネル作業メモツールです。",
  "main": "projects/app/js/app.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "python3 scripts/generate_animation_registry.py && python3 scripts/verify_animations.py && node --experimental-vm-modules ./node_modules/.bin/jest",
    "test:e2e": "python3 scripts/generate_animation_registry.py && playwright test",
    "test:animation-eval": "python3 scripts/generate_animation_registry.py && playwright test tests/animation_evaluation.spec.js",
    "build": "python3 scripts/generate_png_icons.py && python3 scripts/generate_animation_registry.py && python3 scripts/check_version.py && python3 scripts/create_package.py",
    "version:bump": "python3 scripts/bump_version.py",
    "update-guide-images": "node scripts/update_guide_images.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masanori-satake/QuickLog-Solo.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/masanori-satake/QuickLog-Solo/issues"
  },
  "homepage": "https://github.com/masanori-satake/QuickLog-Solo#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.0.2",
    "playwright": "^1.58.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "stylelint": "^17.3.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {}
}
