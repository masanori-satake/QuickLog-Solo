{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "sidePanel",
    "alarms",
    "notifications",
    "clipboardRead"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https://raw.githubusercontent.com;"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "shared/assets/icon16.png",
      "32": "shared/assets/icon32.png",
      "48": "shared/assets/icon48.png",
      "128": "shared/assets/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "app.html"
  },
  "icons": {
    "16": "shared/assets/icon16.png",
    "32": "shared/assets/icon32.png",
    "48": "shared/assets/icon48.png",
    "128": "shared/assets/icon128.png"
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  }
}
