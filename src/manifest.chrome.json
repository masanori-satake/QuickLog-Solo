{
  "manifest_version": 3,
  "name": "QuickLog-Solo",
  "version": "0.4.1",
  "description": "1秒で記録、1秒で集計 - ミニマリスト向けサイドパネル作業メモツール",
  "permissions": [
    "sidePanel"
  ],
  "action": {
    "default_title": "QuickLog-Soloを開く",
    "default_icon": {
      "16": "assets/icon.svg",
      "32": "assets/icon.svg",
      "48": "assets/icon.svg",
      "128": "assets/icon.svg"
    }
  },
  "side_panel": {
    "default_path": "app.html"
  },
  "icons": {
    "16": "assets/icon.svg",
    "32": "assets/icon.svg",
    "48": "assets/icon.svg",
    "128": "assets/icon.svg"
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  }
}
